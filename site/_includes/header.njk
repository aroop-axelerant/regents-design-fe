<header class="header">

  {# ── Left pill: logo + primary nav ── #}
  <div class="header__pill header__left">
    <a href="/" class="header__logo" aria-label="Regent's University London">
      <img src="/public/Logo.svg" alt="Regent's University London" width="32" height="32">
    </a>
    <nav class="header__nav" aria-label="Primary navigation">
      <a href="/foundation/colors.html" class="header__nav-link {% if section == 'foundation' %}header__nav-link--active{% endif %}">
        Foundation
        <svg class="header__nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </a>
      <a href="/components/buttons.html" class="header__nav-link {% if section == 'components' %}header__nav-link--active{% endif %}">
        Components
        <svg class="header__nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </a>
      <a href="/layouts/single-column.html" class="header__nav-link {% if section == 'layouts' %}header__nav-link--active{% endif %}">
        Layouts
        <svg class="header__nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </a>
      <a href="/templates/landing.html" class="header__nav-link {% if section == 'templates' %}header__nav-link--active{% endif %}">Templates</a>
    </nav>
  </div>

  {# ── Right pill: apply + search + menu ── #}
  <div class="header__pill header__right">
    <a href="#" class="header__apply">Apply now</a>
    <div class="header__pill-divider" aria-hidden="true"></div>
    <button class="header__icon-btn" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
    <div class="header__pill-divider" aria-hidden="true"></div>
    <button id="mega-menu-open" class="header__icon-btn" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mega-menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

</header>

{% include "mega-menu.njk" %}
