<div class="docs-section">
  <h2 class="docs-section__title">Spacing Scale</h2>
  <p class="docs-section__description">All spacing is based on a 4px grid. Use these tokens for consistent margins, padding, and gaps.</p>
  <div class="stack stack--8">
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 4px;"></div><span class="spacing-bar__label">--sp-4 (4px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 8px;"></div><span class="spacing-bar__label">--sp-8 (8px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 16px;"></div><span class="spacing-bar__label">--sp-16 (16px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 24px;"></div><span class="spacing-bar__label">--sp-24 (24px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 32px;"></div><span class="spacing-bar__label">--sp-32 (32px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 48px;"></div><span class="spacing-bar__label">--sp-48 (48px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 64px;"></div><span class="spacing-bar__label">--sp-64 (64px)</span></div>
    <div class="spacing-bar"><div class="spacing-bar__visual" style="width: 96px;"></div><span class="spacing-bar__label">--sp-96 (96px)</span></div>
  </div>
</div>

<div class="docs-section">
  <h2 class="docs-section__title">Border Radius</h2>
  <p class="docs-section__description">Consistent rounding across the system.</p>
  <div class="ds-preview">
    <div class="ds-preview__content">
      <div style="width: 80px; height: 80px; background: var(--color-bg-accent); border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center;" class="text-caption">XS (4px)</div>
      <div style="width: 80px; height: 80px; background: var(--color-bg-accent); border-radius: var(--radius-s); display: flex; align-items: center; justify-content: center;" class="text-caption">S (8px)</div>
      <div style="width: 80px; height: 80px; background: var(--color-bg-accent); border-radius: var(--radius-m); display: flex; align-items: center; justify-content: center;" class="text-caption">M (16px)</div>
      <div style="width: 80px; height: 80px; background: var(--color-bg-accent); border-radius: var(--radius-l); display: flex; align-items: center; justify-content: center;" class="text-caption">L (pill)</div>
    </div>
  </div>
</div>

<div class="docs-section">
  <h2 class="docs-section__title">12-Column Grid</h2>
  <p class="docs-section__description">Responsive grid with 4 breakpoints: mobile (&lt;768px), tablet (768–1279px), desktop (1280–1599px), wide (≥1600px).</p>
  <div class="ds-preview">
    <div class="ds-preview__content" style="flex-direction: column; align-items: stretch;">
      <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--sp-8);">
        {% for i in range(1, 13) %}
        <div style="background: var(--color-bg-accent); padding: var(--sp-8); text-align: center; border-radius: var(--radius-xs);" class="text-caption">{{ i }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<div class="docs-section">
  <h2 class="docs-section__title">Breakpoints</h2>
  <div class="stack stack--8">
    <div class="cluster cluster--16"><span class="chip chip--charcoal">Mobile</span> <span class="text-body">&lt; 768px — 16px gutters, 16px gap</span></div>
    <div class="cluster cluster--16"><span class="chip chip--green">Tablet</span> <span class="text-body">768px – 1279px — 32px gutters, 24px gap</span></div>
    <div class="cluster cluster--16"><span class="chip chip--outline">Desktop</span> <span class="text-body">1280px – 1599px — 64px gutters, 32px gap</span></div>
    <div class="cluster cluster--16"><span class="chip chip--yellow">Wide</span> <span class="text-body">≥ 1600px — 80px gutters, 32px gap</span></div>
  </div>
</div>
