<style>
  /* ── Preview page ─────────────────────────────── */
  .pv-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 48px;
  }
  .pv-stat {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-charcoal, #0b191a);
  }
  .pv-stat--foundation { background: var(--color-zingy-yellow, #e0f94c); }
  .pv-stat--components { background: var(--color-violet, #deccf3); }
  .pv-stat--layouts    { background: var(--color-soft-peach, #ffb38f); }
  .pv-stat--templates  { background: var(--color-powdered-blue-50, #abd6f5); }
  .pv-stat--pages      { background: var(--color-charcoal-10, #e7e8e8); }
  .pv-stat__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    background: rgba(11,25,26,.12);
    border-radius: 50%;
    font-size: 11px;
  }

  .pv-section { margin-bottom: 64px; }

  .pv-section__head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 16px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--color-charcoal-20, #ced1d1);
  }
  .pv-section__badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
  }
  .pv-section__badge--foundation { background: var(--color-zingy-yellow, #e0f94c); color: var(--color-charcoal, #0b191a); }
  .pv-section__badge--components { background: var(--color-violet, #deccf3);       color: var(--color-charcoal, #0b191a); }
  .pv-section__badge--layouts    { background: var(--color-soft-peach, #ffb38f);   color: var(--color-charcoal, #0b191a); }
  .pv-section__badge--templates  { background: var(--color-powdered-blue-50, #abd6f5); color: var(--color-charcoal, #0b191a); }
  .pv-section__badge--pages      { background: var(--color-charcoal-10, #e7e8e8);  color: var(--color-charcoal, #0b191a); }

  .pv-section__title {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-charcoal, #0b191a);
    margin: 0;
    letter-spacing: -.01em;
  }
  .pv-section__desc {
    font-size: 13px;
    color: var(--color-charcoal-50, #858d8d);
    margin-left: auto;
    white-space: nowrap;
  }

  .pv-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
  .pv-grid--wide {
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  }

  .pv-card {
    display: block;
    border-radius: 10px;
    border: 1px solid var(--color-charcoal-20, #ced1d1);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #fff;
    transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
  }
  .pv-card:hover {
    box-shadow: 0 8px 28px rgba(11,25,26,.12);
    transform: translateY(-3px);
    border-color: var(--color-charcoal-40, #9da3a3);
  }

  .pv-card__viewport {
    position: relative;
    width: 100%;
    /* 16:9-ish aspect ratio container */
    padding-top: 62%;
    overflow: hidden;
    background: var(--color-off-white, #f9f2e8);
  }
  .pv-card__viewport iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 1280px;
    height: 900px;
    border: none;
    /* scale = card-width / 1280. At 260px card the scale ≈ 0.203 */
    transform: scale(0.203);
    transform-origin: top left;
    pointer-events: none;
  }
  /* Thin overlay so the iframe doesn't capture pointer events */
  .pv-card__viewport::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .pv-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    border-top: 1px solid var(--color-charcoal-20, #ced1d1);
    background: #fff;
  }
  .pv-card__name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-charcoal, #0b191a);
    letter-spacing: -.01em;
  }
  .pv-card__arrow {
    font-size: 14px;
    color: var(--color-charcoal-50, #858d8d);
    transition: transform .18s ease;
  }
  .pv-card:hover .pv-card__arrow { transform: translateX(4px); }
</style>

