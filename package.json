{
  "name": "regents-design-fe",
  "version": "1.0.0",
  "description": "Regent's University London — HTML/CSS/JS Design System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:tokens && concurrently \"npx @11ty/eleventy --serve --port=8080\" \"npx vite\"",
    "build:tokens": "style-dictionary build --config sd.config.js",
    "build:css": "vite build",
    "build:site": "npx @11ty/eleventy",
    "build": "npm run build:tokens && npm run build:css && npm run build:site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^9.1.0",
    "sass": "^1.83.0",
    "style-dictionary": "^4.2.0",
    "vite": "^6.0.0"
  }
}
