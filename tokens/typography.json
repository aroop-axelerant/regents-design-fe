{
  "typography": {
    "font-family": {
      "$type": "fontFamily",
      "serif": { "$value": "Magnole, Playfair Display, Georgia, serif" },
      "sans": { "$value": "Avenir Next, Avenir, DM Sans, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif" }
    },
    "font-weight": {
      "$type": "number",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "font-size": {
      "$type": "dimension",
      "display-2xl": { "$value": "96px" },
      "display-xl": { "$value": "80px" },
      "display-l": { "$value": "64px" },
      "display-m": { "$value": "48px" },
      "display-s": { "$value": "40px" },
      "h1": { "$value": "40px" },
      "h2": { "$value": "32px" },
      "h3": { "$value": "24px" },
      "h4": { "$value": "20px" },
      "h5": { "$value": "16px" },
      "h6": { "$value": "13px" },
      "body-xl": { "$value": "20px" },
      "subtitle": { "$value": "20px" },
      "body-lg": { "$value": "18px" },
      "body": { "$value": "16px" },
      "small": { "$value": "14px" },
      "caption": { "$value": "12px" },
      "overline": { "$value": "11px" },
      "quote-l": { "$value": "28px" },
      "quote-m": { "$value": "22px" },
      "label-xl": { "$value": "18px" },
      "label-l": { "$value": "16px" },
      "label-m": { "$value": "14px" },
      "label-s": { "$value": "12px" },
      "nav-item": { "$value": "16px" },
      "badge": { "$value": "11px" },
      "helper": { "$value": "13px" },
      "tab-label": { "$value": "14px" },
      "tooltip": { "$value": "12px" }
    },
    "line-height": {
      "$type": "number",
      "none": { "$value": 1.0 },
      "tightest": { "$value": 1.05 },
      "tighter": { "$value": 1.1 },
      "tight": { "$value": 1.15 },
      "snug": { "$value": 1.2 },
      "compact": { "$value": 1.25 },
      "normal": { "$value": 1.3 },
      "relaxed": { "$value": 1.4 },
      "comfortable": { "$value": 1.5 },
      "loose": { "$value": 1.55 },
      "spacious": { "$value": 1.6 },
      "airy": { "$value": 1.65 },
      "open": { "$value": 1.7 },
      "generous": { "$value": 1.75 }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tighter": { "$value": "-0.03em" },
      "tight": { "$value": "-0.02em" },
      "snug": { "$value": "-0.01em" },
      "normal": { "$value": "0em" },
      "wide": { "$value": "0.01em" },
      "wider": { "$value": "0.06em" },
      "widest": { "$value": "0.10em" }
    }
  }
}
